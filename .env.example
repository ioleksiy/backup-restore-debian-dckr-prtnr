# Runtime values must be stored in /etc/backup-restore.env.
# Use scripts/setup-env.sh to create/update that file safely.

# Required: restic repository (Hetzner Storage Box via SFTP example)
RESTIC_REPOSITORY='sftp:u123456-sub1@u123456-sub1.your-storagebox.de:/./restic-repo'

# Required: restic encryption password
RESTIC_PASSWORD=''

# Required: workspace root for generated backup content before restic upload
BACKUP_ROOT='/opt/backup-restore'

# Optional but recommended: colon-separated stack/config source paths
# Debian-friendly defaults include /etc/docker/stacks.
STACK_CONFIG_PATHS='/opt/stacks:/srv/stacks:/etc/docker/stacks'

# Optional: Portainer API settings for stack file export
PORTAINER_URL='https://portainer.example.com'
PORTAINER_USERNAME='admin'
PORTAINER_PASSWORD=''
PORTAINER_ENDPOINT_ID='1'

# Required retention policy flags for: restic forget <args>
# Include --prune to prune unused data after applying policy.
RESTIC_FORGET_ARGS='--keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune'

# Optional webhook notifications
# Use a real value only in /etc/backup-restore.env, never in git-tracked files.
SLACK_WEBHOOK_URL='https://example.invalid/slack-webhook'
SLACK_NOTIFY_CHANNEL='#ops-backups'

# Restore defaults
RESTORE_TARGET='/restore-output'
RESTIC_SNAPSHOT='latest'

# Optional host override for restic snapshots
# If empty, scripts use the current hostname.
RESTIC_HOST='debian-swarm-node-01'
